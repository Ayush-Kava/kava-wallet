// Prisma schema for Kava Wallet — PostgreSQL via POSTGRES_URL
// Run `npx prisma migrate dev` to generate SQL migrations and sync the database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

enum UserRole {
  user
  admin
}

enum AccountKind {
  bank
  cash
  wallet
  credit_card
}

enum CategoryType {
  income
  expense
}

enum TransactionType {
  income
  expense
}

enum RecurringType {
  income
  expense
  transfer
}

enum RecurringFrequency {
  weekly
  monthly
  yearly
}

enum GoalPriority {
  low
  medium
  high
}

enum GoalStatus {
  active
  completed
  cancelled
}

enum InvestmentType {
  mutual_fund
  stock
  fd
  gold
  crypto
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  fullName     String?
  role         UserRole @default(user)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  bankAccounts  BankAccount[]
  cashAccounts  CashAccount[]
  walletAccounts WalletAccount[]
  creditCards   CreditCard[]
  categories    Category[]
  transactions  Transaction[]
  budgets       Budget[]
  recurring     RecurringRule[]
  loans         Loan[]
  goals         Goal[]
  goalFunding   GoalFunding[]
  investments   Investment[]
  documents     Document[]
  documentLinks DocumentLink[]
  documentReminders DocumentReminder[]
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// Admin-managed bank master
model Bank {
  id         Int      @id @default(autoincrement())
  publicId   String   @unique @default(uuid()) @db.Uuid
  name       String   @unique
  ifscPrefix String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  bankAccounts BankAccount[]
  creditCards  CreditCard[]
}

model BankAccount {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankId        Int
  bank          Bank     @relation(fields: [bankId], references: [id], onDelete: Restrict)
  name          String
  accountNumber BigInt
  ifscCode      String   @db.VarChar(11)
  balance       Decimal  @default(0) @db.Decimal(15, 2)
  currency      String   @default("INR")
  color         String   @default("#10B981")
  icon          String   @default("landmark")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([bankId])
}

model CashAccount {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  currency  String   @default("INR")
  color     String   @default("#10B981")
  icon      String   @default("banknote")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WalletAccount {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  provider  String?
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  currency  String   @default("INR")
  color     String   @default("#5F259F")
  icon      String   @default("smartphone")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CreditCard {
  id                 Int       @id @default(autoincrement())
  userId             Int
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankId             Int?
  bank               Bank?     @relation(fields: [bankId], references: [id], onDelete: SetNull)
  name               String
  cardNumber         String
  cardHolderName     String?
  expiryDate         DateTime  @db.Date
  creditLimit        Decimal   @db.Decimal(15, 2)
  outstandingBalance Decimal   @default(0) @db.Decimal(15, 2)
  minDue             Decimal?  @db.Decimal(15, 2)
  statementStartDate DateTime? @db.Date
  statementEndDate   DateTime? @db.Date
  dueDate            DateTime? @db.Date
  currency           String    @default("INR")
  color              String    @default("#1A1F71")
  icon               String    @default("credit-card")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([bankId])
}

// Unified ledger pointer — transactions and other modules reference this table
model Account {
  id          Int         @id @default(autoincrement())
  publicId    String      @unique @default(uuid()) @db.Uuid
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        AccountKind
  referenceId Int

  transactions  Transaction[]
  recurring     RecurringRule[] @relation("RecurringAccount")
  recurringFrom RecurringRule[] @relation("RecurringFrom")
  recurringTo   RecurringRule[] @relation("RecurringTo")
  loans         Loan[]
  investments   Investment[]

  @@unique([kind, referenceId])
  @@index([userId])
  @@index([userId, publicId])
}

model Category {
  id         Int          @id @default(autoincrement())
  publicId   String       @unique @default(uuid()) @db.Uuid
  userId     Int?
  user       User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  type       CategoryType
  icon       String       @default("tag")
  color      String       @default("#6366F1")
  is_default Boolean      @default(false)
  createdAt  DateTime     @default(now())

  transactions Transaction[]
  budgets      Budget[]
  loans        Loan[]
  recurring    RecurringRule[]

  @@index([userId])
  @@index([userId, publicId])
}

model Transaction {
  id          Int             @id @default(autoincrement())
  publicId    String          @unique @default(uuid()) @db.Uuid
  userId      Int
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   Int
  account     Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId  Int?
  category    Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  type        TransactionType
  amount      Decimal         @db.Decimal(15, 2)
  description String?
  date        DateTime        @db.Date
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  transfer_id Int?

  @@index([userId])
  @@index([userId, publicId])
  @@index([accountId])
  @@index([transfer_id])
}

model Budget {
  id         Int       @id @default(autoincrement())
  publicId   String    @unique @default(uuid()) @db.Uuid
  userId     Int
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount     Decimal   @db.Decimal(15, 2)
  period     String
  start_date DateTime  @db.Date
  end_date   DateTime? @db.Date
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([userId, publicId])
  @@index([categoryId])
}

model RecurringRule {
  id            Int                @id @default(autoincrement())
  publicId      String             @unique @default(uuid()) @db.Uuid
  userId        Int
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  type          RecurringType
  frequency     RecurringFrequency
  amount        Decimal            @db.Decimal(15, 2)
  accountId     Int?
  account       Account?           @relation("RecurringAccount", fields: [accountId], references: [id], onDelete: Cascade)
  fromAccountId Int?
  fromAccount   Account?           @relation("RecurringFrom", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccountId   Int?
  toAccount     Account?           @relation("RecurringTo", fields: [toAccountId], references: [id], onDelete: Cascade)
  categoryId    Int?
  category      Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  loanId        Int?
  loan          Loan?              @relation(fields: [loanId], references: [id], onDelete: Cascade)
  next_run_date DateTime           @db.Date
  end_date      DateTime?          @db.Date
  paused        Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId])
  @@index([userId, publicId])
  @@index([next_run_date])
  @@index([loanId])
}

model Loan {
  id                  Int       @id @default(autoincrement())
  publicId            String    @unique @default(uuid()) @db.Uuid
  userId              Int
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  principal           Decimal   @db.Decimal(12, 2)
  interest_rate       Decimal   @db.Decimal(5, 2)
  tenure_months       Int
  emi_amount          Decimal   @db.Decimal(12, 2)
  start_date          DateTime  @db.Date
  accountId           Int
  account             Account   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  categoryId          Int?
  category            Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  outstanding_balance Decimal   @default(0) @db.Decimal(12, 2)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  recurringRules RecurringRule[]

  @@index([userId])
  @@index([userId, publicId])
  @@index([accountId])
  @@index([categoryId])
}

model Goal {
  id            Int          @id @default(autoincrement())
  publicId      String       @unique @default(uuid()) @db.Uuid
  userId        Int
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  target_amount Decimal      @db.Decimal(15, 2)
  target_date   DateTime     @db.Date
  priority      GoalPriority @default(medium)
  status        GoalStatus   @default(active)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  funding GoalFunding[]

  @@index([userId])
  @@index([userId, publicId])
  @@index([status])
  @@index([priority])
  @@index([target_date])
}

model GoalFunding {
  id                  Int      @id @default(autoincrement())
  publicId            String   @unique @default(uuid()) @db.Uuid
  goalId              Int
  goal                Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  userId              Int
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source_type         String
  source_public_id    String   @db.Uuid
  allocated_amount    Decimal  @db.Decimal(15, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([goalId, source_type, source_public_id])
  @@index([userId])
  @@index([userId, publicId])
}

model Investment {
  id              Int            @id @default(autoincrement())
  publicId        String         @unique @default(uuid()) @db.Uuid
  userId          Int
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  type            InvestmentType
  invested_amount Decimal        @db.Decimal(15, 2)
  current_value   Decimal        @db.Decimal(15, 2)
  accountId       Int
  account         Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  start_date      DateTime       @db.Timestamptz(6)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([userId, publicId])
  @@index([accountId])
  @@index([type])
}

model Document {
  id             Int      @id @default(autoincrement())
  publicId       String   @unique @default(uuid()) @db.Uuid
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  file_url       String
  file_type      String
  file_extension String   @default("")
  mime_type      String   @default("application/octet-stream")
  file_size      Int
  tags           String[] @default([])
  notes          String?
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  links     DocumentLink[]
  reminders DocumentReminder[]

  @@index([userId])
  @@index([userId, publicId])
  @@index([archived])
}

model DocumentLink {
  id                      Int      @id @default(autoincrement())
  publicId                String   @unique @default(uuid()) @db.Uuid
  documentId              Int
  document                Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId                  Int
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  linked_entity_type      String
  linked_entity_public_id String   @db.Uuid
  createdAt               DateTime @default(now())

  @@index([documentId])
  @@index([userId])
  @@index([linked_entity_type, linked_entity_public_id])
}

model DocumentReminder {
  id            Int      @id @default(autoincrement())
  publicId      String   @unique @default(uuid()) @db.Uuid
  documentId    Int
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminder_type String
  reminder_date DateTime @db.Date
  title         String
  description   String?
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([documentId])
  @@index([userId])
  @@index([userId, publicId])
  @@index([reminder_date])
}
