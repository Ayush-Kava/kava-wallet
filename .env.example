# PostgreSQL connection string
POSTGRES_URL=postgresql://user:password@localhost:5432/kava_wallet

# Session lifetime in minutes (default: 20160 = 14 days)
SESSION_EXPIRE_MINUTES=20160

# Cloudflare R2 (document uploads)
# R2_ENDPOINT: account URL only — do NOT append /bucket-name (use R2_BUCKET_NAME for that)
# R2_BUCKET_NAME: exact bucket name in Cloudflare (not a folder path)
# R2_PUBLIC_URL: r2.dev or custom domain from that bucket's Public Access settings
# Also add a CORS policy on the bucket (Settings → CORS) allowing PUT from your app origin.
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kava-wallet-docs
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
